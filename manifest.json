{
  "manifest_version": 3,
  "name": "Feedback Capture",
  "version": "1.0.0",
  "description": "Capture design feedback on any live prototype. Select elements, add notes, export a clean report.",
  "permissions": ["storage", "scripting", "tabs", "unlimitedStorage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Feedback Capture"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
